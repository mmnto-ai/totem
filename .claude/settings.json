{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-context.mjs"
          }
        ],
        "matcher": ""
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .totem/hooks/merge-interlock.cjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm view *)",
      "Bash(gdlint *)",
      "Bash(gh search *)",
      "mcp__totem-dev__search_knowledge",
      "mcp__totem-strategy__search_knowledge"
    ]
  }
}
