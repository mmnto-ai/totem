+/// Bytes per packed [`GibEvent`] record in the `get_gib_events` FFI buffer.
+/// The GDScript gib renderer MUST mirror this stride + the `GIB_OFF_*`
+/// offsets; `gib_event_abi_layout_is_stable` locks the Rust side and the
+/// GDScript parity test locks the bridge. Layout (little-endian):
+/// `[0]u32 slot · [4]u32 tick · [8]u32 seed · [12]f32 pos_x · [16]f32 pos_y ·
+/// [20]f32 pos_z(world) · [24]f32 vel_x · [28]f32 vel_y · [32]f32 vel_z`.
+pub const GIB_EVENT_STRIDE: usize = 36;
+pub const GIB_OFF_SLOT: usize = 0;
+pub const GIB_OFF_TICK: usize = 4;
+pub const GIB_OFF_SEED: usize = 8;
+pub const GIB_OFF_POS_X: usize = 12;
+pub const GIB_OFF_POS_Y: usize = 16;
+pub const GIB_OFF_POS_Z: usize = 20;
+pub const GIB_OFF_VEL_X: usize = 24;
+pub const GIB_OFF_VEL_Y: usize = 28;
+pub const GIB_OFF_VEL_Z: usize = 32;
