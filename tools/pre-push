#!/bin/sh
# [totem] pre-push hook — runs format check, lint, tests, and deterministic shield.

echo "[totem] Running pre-push checks..."

# Ensure temp files are cleaned up on any exit (success, failure, or interrupt)
LINT_OUTPUT=""
TEST_OUTPUT=""
cleanup() { rm -f "$LINT_OUTPUT" "$TEST_OUTPUT"; }
trap cleanup EXIT INT TERM

echo "[totem] Checking formatting..."
pnpm run format:check
if [ $? -ne 0 ]; then
  echo "[totem] ❌ Formatting check failed. Run 'pnpm run format' to fix."
  exit 1
fi

echo "[totem] Running linter..."
LINT_OUTPUT=$(mktemp)
pnpm run lint > "$LINT_OUTPUT" 2>&1
LINT_EXIT=$?
if [ $LINT_EXIT -ne 0 ]; then
  echo "[totem] ❌ Lint failed. See output below:"
  cat "$LINT_OUTPUT"
  exit 1
fi

echo "[totem] Running tests..."
TEST_OUTPUT=$(mktemp)
if [ "${TOTEM_DEBUG:-0}" = "1" ]; then
  pnpm run test > "$TEST_OUTPUT" 2>&1
else
  pnpm run test -- --reporter=dot > "$TEST_OUTPUT" 2>&1
fi
TEST_EXIT=$?
if [ $TEST_EXIT -ne 0 ]; then
  echo "[totem] ❌ Tests failed. Re-running with full output:"
  pnpm run test 2>&1 | tail -40
  exit 1
fi
# Count passed tests from vitest summary lines (match "Tests" but not "Test Files")
PASSED=$(sed 's/\x1b\[[0-9;]*m//g' "$TEST_OUTPUT" | grep 'Tests ' | grep -v 'Test Files' | grep -oE '[0-9]+ passed' | awk '{s+=$1} END {print s}')
echo "[totem] ✓ ${PASSED:-all} tests passed"

echo "[totem] ✅ All pre-push checks passed."

# Deterministic shield gate — only runs when compiled rules exist AND CLI is available.
if [ -f ".totem/compiled-rules.json" ] && pnpm exec totem --version > /dev/null 2>&1; then
  echo "[totem] Running deterministic shield..."
  pnpm exec totem shield --deterministic
  if [ $? -ne 0 ]; then
    echo "[totem] ❌ Deterministic shield found violations. Fix before pushing."
    echo "[totem] If this is a false positive, file a ticket. Do not bypass without approval."
    exit 1
  fi
  echo "[totem] ✅ Deterministic shield passed."
fi
